---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'min-w-0 max-w-full border border-neutral-800 bg-zinc-950 shadow-[0_0_40px_rgba(45,212,191,0.06)]',
    className,
  ]}
>
  <div class="flex items-center gap-2 border-b border-neutral-800 bg-neutral-900/80 px-4 py-3">
    <span class="h-3 w-3 bg-red-500/90" aria-hidden="true"></span>
    <span class="h-3 w-3 bg-amber-400/90" aria-hidden="true"></span>
    <span class="h-3 w-3 bg-emerald-500/90" aria-hidden="true"></span>
    <span class="mono ml-3 min-w-0 truncate text-[10px] tracking-widest text-zinc-500 uppercase">
      <slot name="filename" />
    </span>
  </div>
  <div class="relative min-w-0 max-w-full">
    <slot />
    <span
      class="pointer-events-none absolute right-4 bottom-4 inline-block h-4 w-0.5 animate-pulse bg-teal-400"
      x-show="$store.codePreview.typing"
      x-cloak
      aria-hidden="true"
    ></span>
  </div>
</div>
