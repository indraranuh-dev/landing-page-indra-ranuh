---
import { copy } from '../../content/copy';
---

<div
  x-show="$store.projectModal.activeId"
  x-cloak
  class="fixed inset-0 z-[80] flex items-end justify-center p-0 sm:items-center sm:p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="project-modal-title"
>
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" @click="$store.projectModal.close()"></div>

  <div
    class="modal-panel relative z-10 w-full max-w-4xl "
    @click.stop
    x-transition
  >
    <div class="p-6 sm:p-10">
      <div class="mb-6 flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p
            class="micro-label mb-2"
            x-text="$store.projectModal.active ? '// CASE_STUDY · ' + $store.projectModal.active.id : ''"
          >
          </p>
          <h2
            id="project-modal-title"
            class="text-2xl font-extrabold tracking-tight text-zinc-100 sm:text-3xl"
            x-text="$store.projectModal.active?.title ?? ''"
          >
          </h2>
          <p class="mono mt-2 text-xs text-zinc-500">
            <span x-text="$store.projectModal.active?.role ?? ''"></span>
            <span class="mx-1">·</span>
            <span x-text="$store.projectModal.active?.year ?? ''"></span>
          </p>
        </div>
        <button
          type="button"
          class="flex h-10 w-10 shrink-0 items-center justify-center border border-neutral-800 text-zinc-300 transition-colors hover:border-teal-400 hover:text-teal-400"
          @click="$store.projectModal.close()"
          aria-label={copy.projects.closeModal}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>

      <div class="grid gap-px bg-neutral-800 md:grid-cols-12">
        <div class="blueprint-cell space-y-6 p-6 md:col-span-7">
          <div>
            <p class="micro-label mb-2 flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="shrink-0 text-zinc-600"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 16v-4"></path>
                <path d="M12 8h.01"></path>
              </svg>
              {copy.projects.modalProblem}
            </p>
            <p
              class="text-sm leading-relaxed text-zinc-400"
              x-text="$store.projectModal.active?.problem ?? ''"
            >
            </p>
          </div>
          <div>
            <p class="micro-label mb-2 flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="shrink-0 text-zinc-600"
                aria-hidden="true"
              >
                <path d="M12 20h9"></path>
                <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
              </svg>
              {copy.projects.modalSolution}
            </p>
            <p
              class="text-sm leading-relaxed text-zinc-300"
              x-text="$store.projectModal.active?.solution ?? ''"
            >
            </p>
          </div>
          <p
            class="text-sm leading-relaxed text-zinc-500"
            x-text="$store.projectModal.active?.description ?? ''"
          >
          </p>
          <div>
            <p class="micro-label mb-2 flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="shrink-0 text-teal-500"
                aria-hidden="true"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <path d="m22 4-10 10-4-4"></path>
              </svg>
              {copy.projects.modalImpact}
            </p>
            <ul class="space-y-2">
              <template x-for="item in $store.projectModal.active?.highlights ?? []" :key="item">
                <li class="flex gap-2 text-sm text-zinc-400">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    class="mt-0.5 shrink-0 text-teal-400"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                  <span x-text="item"></span>
                </li>
              </template>
            </ul>
          </div>
        </div>

        <div class="blueprint-cell relative p-6 md:col-span-5">
          <div class="glow-accent glow-cyan -right-8 -top-8 h-40 w-40"></div>
          <div class="glow-accent glow-violet bottom-0 left-0 h-32 w-32"></div>
          <div class="relative space-y-4">
            <div class="flex flex-wrap gap-2">
              <span
                class="mono border px-3 py-1 text-[10px] tracking-widest uppercase"
                :class="$store.projectModal.active?.badgeClass"
                x-text="$store.projectModal.active?.badge"
              >
              </span>
              <span
                x-show="$store.projectModal.active && !$store.projectModal.active.url"
                class="mono border border-pink-400/30 px-3 py-1 text-[10px] tracking-widest text-pink-400 uppercase"
              >
                PRIVATE
              </span>
            </div>
            <div>
              <p class="micro-label mb-2 flex items-center gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="shrink-0 text-zinc-600"
                  aria-hidden="true"
                >
                  <rect width="20" height="8" x="2" y="2" ></rect>
                  <rect width="20" height="8" x="2" y="14" ></rect>
                  <path d="M6 6h.01"></path>
                  <path d="M6 18h.01"></path>
                </svg>
                {copy.projects.modalStack}
              </p>
              <div class="flex flex-wrap gap-2">
                <template x-for="tech in $store.projectModal.active?.stack ?? []" :key="tech">
                  <span
                    class="mono border border-neutral-800 bg-neutral-950 px-2 py-1 text-[10px] text-zinc-500"
                    x-text="tech"
                  ></span>
                </template>
              </div>
            </div>
            <div class="flex flex-wrap gap-2 border-t border-neutral-800 pt-4">
              <template x-for="tag in $store.projectModal.active?.tags ?? []" :key="tag">
                <span class="mono text-[10px] text-zinc-600" x-text="tag"></span>
              </template>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 flex flex-col gap-3 border-t border-neutral-800 pt-6 sm:flex-row sm:justify-end">
        <button
          type="button"
          class="border border-neutral-800 px-6 py-3 text-xs font-bold tracking-widest uppercase transition-colors hover:border-zinc-100"
          @click="$store.projectModal.close()"
        >
          {copy.projects.closeModal}
        </button>
        <a
          x-show="$store.projectModal.active?.url"
          :href="$store.projectModal.active?.url"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-zinc-100 px-6 py-3 text-center text-xs font-bold tracking-widest text-zinc-950 uppercase transition-all hover:bg-teal-400"
        >
          {copy.projects.visitLive}
        </a>
      </div>
    </div>
  </div>
</div>
