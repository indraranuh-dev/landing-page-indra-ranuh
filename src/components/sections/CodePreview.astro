---
import { copy } from '../../content/copy';
import Container from '../ui/Container.astro';
import CodeEditor from '../ui/CodeEditor.astro';
---

<section
  id="code"
  class="blueprint-shell border-t border-zinc-900 py-16 sm:py-24"
  x-data
  x-init="
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          $store.codePreview.initWhenVisible();
          observer.disconnect();
        }
      },
      { rootMargin: '200px' }
    );
    observer.observe($el);
  "
>
  <Container>
    <div class="mb-8 flex flex-col gap-4 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="section-label">{copy.codePreview.sectionLabel}</p>
        <h2 class="mt-2 text-2xl font-bold tracking-tight sm:text-3xl">{copy.codePreview.title}</h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-zinc-400">{copy.codePreview.intro}</p>
      </div>
      <div class="flex flex-wrap gap-2" role="tablist" aria-label={copy.codePreview.tabListLabel}>
        <template x-for="tab in $store.codePreview.snippets" :key="tab.id">
          <button
            type="button"
            role="tab"
            class="mono border px-3 py-1.5 text-[10px] tracking-widest uppercase transition-colors"
            :class="$store.codePreview.activeId === tab.id
              ? 'border-teal-500/60 bg-teal-500/10 text-teal-400'
              : 'border-zinc-800 text-zinc-500 hover:border-zinc-600 hover:text-zinc-300'"
            :aria-selected="$store.codePreview.activeId === tab.id"
            @click="$store.codePreview.selectTab(tab.id)"
            x-text="tab.label"
          ></button>
        </template>
      </div>
    </div>

    <div class="blueprint-grid-gap grid md:grid-cols-[1fr_280px]">
      <div class="blueprint-cell p-0">
        <CodeEditor>
          <span slot="filename" x-text="$store.codePreview.active?.filename ?? 'snippet.txt'"></span>
          <pre
            class="code-preview-pre max-h-[min(420px,50vh)] overflow-auto p-4 text-[11px] leading-relaxed sm:p-6 sm:text-xs"
          ><code
              class="hljs mono block whitespace-pre"
              :class="'language-' + ($store.codePreview.active?.language ?? 'plaintext')"
              x-html="$store.codePreview.highlightedHtml"
            ></code></pre>
        </CodeEditor>
      </div>
      <aside class="blueprint-cell flex flex-col justify-between gap-6 p-6">
        <div>
          <p class="section-label text-[9px]">{copy.codePreview.asideLabel}</p>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">{copy.codePreview.asideBody}</p>
        </div>
        <ul class="space-y-2 text-[11px] text-zinc-500">
          {
            copy.codePreview.highlights.map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 h-1 w-1 shrink-0 bg-teal-400" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>
      </aside>
    </div>
  </Container>
</section>
