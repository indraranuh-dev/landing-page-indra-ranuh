---
import { copy } from '../../content/copy';
import Container from '../ui/Container.astro';
---

<section
  id="philosophy"
  class="relative overflow-hidden border-y border-neutral-800/50 bg-black/50 px-4 py-20 sm:px-6 sm:py-32"
>
  <div
    class="glow-accent glow-cyan top-0 right-0 h-[min(480px,75vw)] w-[min(480px,75vw)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="glow-accent glow-violet bottom-0 left-0 h-[min(360px,55vw)] w-[min(360px,55vw)]"
    aria-hidden="true"
  >
  </div>

  <Container class="relative z-10">
    <p class="section-label">{copy.philosophy.sectionLabel}</p>

    <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="reveal-phil lg:col-span-7">
        <h2 class="mono mb-6 text-xs tracking-[0.35em] text-teal-400 uppercase sm:mb-8 sm:text-sm sm:tracking-[0.4em]">
          {copy.philosophy.sectionTitle}
        </h2>

        <blockquote class="text-gradient mb-8 text-2xl leading-snug font-bold tracking-tight sm:mb-10 sm:text-4xl lg:text-[2.75rem]">
          &ldquo;{copy.philosophy.quote}&rdquo;
        </blockquote>

        <p class="mb-10 max-w-2xl text-base leading-relaxed text-zinc-400 sm:text-lg">
          {copy.philosophy.body}
          <strong class="text-zinc-200">{copy.philosophy.bodyStrong}</strong>{copy.philosophy.bodyAfter}
        </p>

        <div class="grid grid-cols-1 gap-px border border-neutral-800 bg-neutral-800 sm:grid-cols-3">
          {
            copy.philosophy.tags.map((tag) => (
              <div class="blueprint-cell px-4 py-3 sm:py-4">
                <span class="mono text-[10px] tracking-widest text-zinc-300 uppercase">{tag}</span>
              </div>
            ))
          }
        </div>
      </div>

      <aside class="reveal-phil-card relative lg:col-span-5">
        <div class="relative overflow-hidden border border-neutral-800 bg-black/90 p-6 backdrop-blur-sm sm:p-10">
          <div
            class="glow-accent glow-cyan -top-16 -right-16 h-40 w-40 opacity-70"
            aria-hidden="true"
          >
          </div>

          <div class="relative z-10">
            <p class="micro-label mb-3">{copy.philosophy.rndLabel}</p>
            <h3 class="mb-4 text-xl font-bold tracking-tight text-zinc-100 sm:text-2xl">
              {copy.philosophy.rndTitle}
            </h3>
            <p class="mb-8 text-sm leading-relaxed text-zinc-500 sm:text-base">
              {copy.philosophy.rndDescription}
            </p>

            <div class="border-t border-zinc-800 pt-6">
              <div class="mb-3 flex items-center justify-between gap-4">
                <span class="mono text-[10px] tracking-widest text-zinc-500 uppercase">
                  {copy.philosophy.rndProgress}
                </span>
                <span class="mono text-[10px] text-teal-400">75%</span>
              </div>
              <div class="h-1 w-full overflow-hidden bg-zinc-800">
                <div class="h-full w-[75%] bg-teal-400"></div>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </Container>
</section>
