---
import { copy } from "../../content/copy";
import Container from "../ui/Container.astro";

const { metrics, terminal } = copy.vibeMetrics;

const lineClass = (kind: (typeof terminal.lines)[number]["kind"]) => {
  if (kind === "cmd") return "text-teal-400";
  if (kind === "ok") return "text-emerald-400";
  return "text-zinc-400";
};
---

<section
  id="metrics"
  class="border-t border-zinc-900 px-4 py-16 sm:px-6 sm:py-24"
>
  <Container>
    <p class="section-label">{copy.vibeMetrics.sectionLabel}</p>
    <div class="blueprint-grid-gap grid lg:grid-cols-2">
      <div class="blueprint-cell p-6 sm:p-8">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {copy.vibeMetrics.title}
        </h2>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-zinc-500">
          {copy.vibeMetrics.intro}
        </p>
        <dl class="mt-8 grid grid-cols-2 gap-px bg-zinc-800 sm:grid-cols-4">
          {
            metrics.map((metric) => (
              <div class="bg-black p-4">
                <dt class="mono text-[9px] tracking-widest text-zinc-600 uppercase">
                  {metric.label}
                </dt>
                <dd class="mt-2 text-xl font-bold text-teal-400 sm:text-2xl">
                  {metric.value}
                </dd>
                <dd class="mt-1 text-[10px] text-zinc-500">{metric.hint}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="blueprint-cell overflow-hidden">
        <div
          class="flex items-center gap-2 border-b border-zinc-800 bg-zinc-950 px-4 py-3"
        >
          <span
            class="h-2.5 w-2.5 bg-red-500/80"
            aria-hidden="true"></span>
          <span
            class="h-2.5 w-2.5 bg-amber-400/80"
            aria-hidden="true"></span>
          <span
            class="h-2.5 w-2.5 bg-emerald-500/80"
            aria-hidden="true"></span>
          <span class="mono ml-2 text-[10px] text-zinc-600"
            >{terminal.windowTitle}</span
          >
        </div>
        <pre
          class="mono max-h-80 overflow-auto p-4 text-[11px] leading-relaxed sm:p-6 sm:text-xs"
          aria-label={terminal.ariaLabel}><code>{
              terminal.lines.map((line, index) => (
                <>
                  {index > 0 ? '\n' : ''}
                  <span class={lineClass(line.kind)}>{line.text}</span>
                </>
              ))
            }</code></pre>
      </div>
    </div>
  </Container>
</section>
