---
import { CreditCard, Fingerprint } from '@lucide/astro';
import { copy } from '../../content/copy';
import Container from '../ui/Container.astro';

const { snap, pg, enterprise } = copy.expertise.cards;
---

<section id="expertise" class="border-y border-neutral-800/50 bg-black/50 px-4 py-20 sm:px-6 sm:py-32">
  <Container>
    <p class="section-label">{copy.expertise.sectionLabel}</p>
    <div class="mb-12 grid gap-8 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-5">
        <h2 class="mb-4 text-3xl font-extrabold tracking-tight sm:mb-6 sm:text-4xl">{copy.expertise.title}</h2>
        <p class="leading-relaxed text-zinc-500">{copy.expertise.intro}</p>
      </div>
      <div class="grid grid-cols-3 gap-px bg-neutral-800 lg:col-span-7">
        <div class="blueprint-cell p-4">
          <div class="mono mb-1 text-[10px] tracking-widest text-teal-400 uppercase">
            {copy.expertise.stackLabels.core}
          </div>
          <div class="font-bold">PHP & Laravel</div>
        </div>
        <div class="blueprint-cell p-4">
          <div class="mono mb-1 text-[10px] tracking-widest text-teal-400 uppercase">
            {copy.expertise.stackLabels.highPerf}
          </div>
          <div class="font-bold">Node.js</div>
        </div>
        <div class="blueprint-cell p-4">
          <div class="mono mb-1 text-[10px] tracking-widest text-zinc-500 uppercase">
            {copy.expertise.stackLabels.scripting}
          </div>
          <div class="font-bold text-zinc-300">Python</div>
        </div>
      </div>
    </div>

    <div class="grid gap-px bg-neutral-800 md:grid-cols-12">
      <article class="expertise-card p-6 md:col-span-7 md:p-10">
        <p class="micro-label mb-4">// module · snap_direct</p>
        <Fingerprint class="mb-6 h-10 w-10 text-teal-400" stroke-width={1} />
        <h4 class="mb-4 text-xl font-bold text-zinc-100">{snap.title}</h4>
        <p class="mb-6 text-sm leading-relaxed text-zinc-500">{snap.description}</p>
        <div class="flex flex-wrap gap-2">
          {snap.tags.map((tag) => (
            <span class="mono border border-neutral-800 bg-neutral-950 px-3 py-1 text-[10px]">{tag}</span>
          ))}
        </div>
      </article>

      <article class="expertise-card p-6 md:col-span-5 md:p-10">
        <p class="micro-label mb-4">// module · pg_integration</p>
        <CreditCard class="mb-6 h-10 w-10 text-teal-400" stroke-width={1} />
        <h4 class="mb-4 text-xl font-bold text-zinc-100">{pg.title}</h4>
        <p class="mb-6 text-sm leading-relaxed text-zinc-500">{pg.description}</p>
        <div class="flex flex-wrap gap-2">
          {pg.tags.map((tag) => (
            <span class="mono border border-neutral-800 bg-neutral-950 px-3 py-1 text-[10px]">{tag}</span>
          ))}
        </div>
      </article>

      <article class="expertise-card p-6 md:col-span-12 md:p-10">
        <p class="micro-label mb-4">// module · enterprise_stack · layered_architecture</p>
        <h4 class="mb-3 text-xl font-bold text-zinc-100">{enterprise.title}</h4>
        <p class="mb-6 max-w-3xl text-sm leading-relaxed text-zinc-500">{enterprise.description}</p>
        <div class="grid gap-px bg-neutral-800 sm:grid-cols-2 lg:grid-cols-4">
          {
            enterprise.layers.map((layer) => (
              <div class="blueprint-cell p-4">
                <p class="mono mb-3 text-[10px] tracking-widest text-teal-400 uppercase">{layer.label}</p>
                <ul class="space-y-1.5">
                  {layer.items.map((item) => (
                    <li class="text-sm text-zinc-300">{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
        <div class="mt-6 flex flex-wrap gap-2 border-t border-neutral-800 pt-6">
          {enterprise.tags.map((tag) => (
            <span class="mono border border-neutral-800 bg-neutral-950 px-3 py-1 text-[10px]">{tag}</span>
          ))}
        </div>
      </article>
    </div>
  </Container>
</section>
